{
  "name": "bible-app",
  "version": "0.0.1",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --host 0.0.0.0",
    "build": "ng build --configuration=production && npm run build:post",
    "build:post": "node scripts/write-build-info.mjs",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:coverage": "ng test --watch=false --code-coverage",
    "biome": "npx @biomejs/biome check --write --unsafe ./src",
    "cap:sync": "npx cap sync",
    "cap:icons": "npx @capacitor/assets generate --assetPath assets --android --ios",
    "cap:ios": "npx cap add ios && npx cap sync ios && npm run cap:icons",
    "cap:android": "npx cap add android && npx cap sync android && npm run cap:icons"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.2.7",
    "@angular/cdk": "^21.2.5",
    "@angular/common": "^21.2.7",
    "@angular/compiler": "^21.2.7",
    "@angular/core": "^21.2.7",
    "@angular/forms": "^21.2.7",
    "@angular/material": "^21.2.5",
    "@angular/platform-browser": "^21.2.7",
    "@angular/platform-browser-dynamic": "^21.2.7",
    "@angular/router": "^21.2.7",
    "@angular/service-worker": "^21.2.7",
    "@capacitor/android": "^8.3.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.3.0",
    "@capacitor/ios": "^8.3.0",
    "@capacitor/network": "^8.0.1",
    "@capacitor/share": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@vercel/speed-insights": "^2.0.0",
    "bootstrap": "^5.3.8",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1",
    "zone.js": "~0.16.1"
  },
  "devDependencies": {
    "@angular/build": "^21.2.6",
    "@angular/cli": "^21.2.6",
    "@angular/compiler-cli": "^21.2.7",
    "@angular/localize": "^21.2.7",
    "@biomejs/biome": "^2.4.10",
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.3.0",
    "@types/jasmine": "~6.0.0",
    "@types/node": "^25.5.2",
    "baseline-browser-mapping": "^2.10.15",
    "jasmine-core": "~6.1.0",
    "karma": "~6.4.4",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.1",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.2.0",
    "puppeteer": "^24.40.0",
    "typescript": "~5.9.3"
  },
  "overrides": {
    "@xmldom/xmldom": "^0.8.12",
    "tar": "^7.5.11",
    "minimatch": "^3.1.5"
  }
}